# Microsoft Graph OAuth
MS_CLIENT_SECRET=

# Token encryption key (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
TOKEN_ENCRYPTION_KEY=

# AWS — Uses ~/.aws/credentials or environment variables
AWS_REGION=us-west-2
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Bedrock Agent & Knowledge Base IDs (set after creating in AWS Console)
BEDROCK_AGENT_ID=
BEDROCK_AGENT_ALIAS_ID=
BEDROCK_KB_ID=
BEDROCK_KB_DATA_SOURCE_ID=

# S3 bucket name for content storage
S3_BUCKET_NAME=

# Logging
LOG_LEVEL=info
